<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Archives - Portfolio Inquiries</title>
  <!-- Google Fonts Outfit & Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --bg-primary: #09090b;
      --bg-secondary: #0f0f13;
      --card-bg: rgba(24, 24, 27, 0.5);
      --accent: #6366f1;
      --accent-hover: #4f46e5;
      --text-main: #f4f4f5;
      --text-muted: #a1a1aa;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
      --border-color: rgba(255, 255, 255, 0.08);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #07090e 0%, #030305 50%, #0d0a1c 100%);
      color: var(--text-main);
      min-height: 100vh;
      position: relative;
    }

    /* Ambient glows */
    body::before, body::after {
      content: '';
      position: absolute;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      filter: blur(150px);
      z-index: -1;
      opacity: 0.1;
      pointer-events: none;
    }

    body::before {
      background: #8b5cf6;
      top: 10%;
      left: 5%;
    }

    body::after {
      background: var(--accent);
      bottom: 15%;
      right: 5%;
    }

    .navbar {
      border-bottom: 1px solid var(--border-color);
      background: rgba(9, 9, 11, 0.7);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .nav-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 18px 24px;
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 20px;
    }

    .brand {
      margin-right: auto;
      font-family: 'Outfit', sans-serif;
      font-size: 1.5rem;
      font-weight: 700;
      background: linear-gradient(to right, #fff, #a5b4fc);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .brand-dot {
      width: 8px;
      height: 8px;
      background: #8b5cf6;
      border-radius: 50%;
      box-shadow: 0 0 10px #8b5cf6;
    }

    .nav-link {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.95rem;
      font-weight: 500;
      transition: color 0.3s;
    }

    .nav-link:hover, .nav-link.active {
      color: var(--text-main);
    }

    .btn-logout {
      padding: 10px 18px;
      border: 1px solid var(--border-color);
      background: rgba(244, 63, 94, 0.05);
      color: #f43f5e;
      border-radius: 10px;
      font-size: 0.9rem;
      font-weight: 500;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .btn-logout:hover {
      background: #f43f5e;
      color: #fff;
      box-shadow: 0 4px 15px rgba(244, 63, 94, 0.3);
      transform: translateY(-1px);
    }

    .main-content {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 24px;
      animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .welcome-header {
      margin-bottom: 36px;
    }

    .welcome-header h2 {
      font-family: 'Outfit', sans-serif;
      font-size: 2.2rem;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .welcome-header p {
      color: var(--text-muted);
      font-size: 1.05rem;
    }

    /* Stats Grid */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
      margin-bottom: 40px;
    }

    .stats-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 24px;
      display: flex;
      flex-direction: column;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    .stats-title {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 8px;
    }

    .stats-value {
      font-family: 'Outfit', sans-serif;
      font-size: 2.5rem;
      font-weight: 700;
      color: #fff;
    }

    /* Search Bar */
    .controls-panel {
      margin-bottom: 30px;
      background: rgba(24, 24, 27, 0.3);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 20px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    .search-form {
      display: flex;
      gap: 12px;
    }

    .search-input {
      flex: 1;
      padding: 12px 16px;
      background: rgba(9, 9, 11, 0.6);
      border: 1px solid var(--border-color);
      border-radius: 10px;
      color: #fff;
      font-family: inherit;
      font-size: 0.95rem;
      transition: all 0.3s;
    }

    .search-input:focus {
      outline: none;
      border-color: #8b5cf6;
      box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.15);
    }

    .btn-search {
      padding: 12px 24px;
      background: #8b5cf6;
      color: #fff;
      border: none;
      border-radius: 10px;
      font-family: inherit;
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      transition: all 0.3s;
    }

    .btn-search:hover {
      background: #7c3aed;
    }

    .btn-clear-search {
      padding: 12px 20px;
      background: transparent;
      color: var(--text-muted);
      border: 1px solid var(--border-color);
      border-radius: 10px;
      font-family: inherit;
      font-weight: 500;
      font-size: 0.95rem;
      text-decoration: none;
      text-align: center;
      transition: all 0.3s;
    }

    .btn-clear-search:hover {
      border-color: var(--text-muted);
      color: #fff;
    }

    /* Message Cards */
    .section-title {
      font-family: 'Outfit', sans-serif;
      font-size: 1.4rem;
      font-weight: 600;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .badge-count {
      background: rgba(139, 92, 246, 0.15);
      color: #8b5cf6;
      padding: 2px 10px;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 600;
    }

    .requests-list {
      display: flex;
      flex-direction: column;
      gap: 20px;
      margin-bottom: 30px;
    }

    .request-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 18px;
      padding: 28px;
      position: relative;
      overflow: hidden;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      transition: all 0.3s ease;
    }

    .request-card::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 4px;
      background: #8b5cf6;
      border-radius: 4px 0 0 4px;
      transition: width 0.2s ease;
    }

    .request-card:hover {
      border-color: rgba(139, 92, 246, 0.3);
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
    }

    .request-card:hover::before {
      width: 6px;
    }

    .request-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 20px;
    }

    .sender-info h3 {
      font-family: 'Outfit', sans-serif;
      font-size: 1.25rem;
      font-weight: 600;
      color: #fff;
      margin-bottom: 4px;
    }

    .sender-email {
      color: var(--text-muted);
      font-size: 0.9rem;
      text-decoration: none;
      transition: color 0.2s;
    }

    .sender-email:hover {
      color: #8b5cf6;
      text-decoration: underline;
    }

    .request-date {
      font-size: 0.85rem;
      color: var(--text-muted);
      background: rgba(255, 255, 255, 0.04);
      padding: 6px 12px;
      border-radius: 8px;
      border: 1px solid var(--border-color);
    }

    .request-subject {
      font-size: 1rem;
      font-weight: 600;
      color: #fff;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .subject-prefix {
      color: #8b5cf6;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 700;
    }

    .request-message {
      background: rgba(0, 0, 0, 0.2);
      border-radius: 12px;
      padding: 18px;
      color: #e4e4e7;
      font-size: 0.95rem;
      line-height: 1.6;
      border: 1px solid rgba(255, 255, 255, 0.02);
      margin-bottom: 20px;
      white-space: pre-wrap;
    }

    .actions {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }

    .btn-action-form {
      display: inline;
    }

    .btn-restore, .btn-delete {
      padding: 10px 18px;
      border-radius: 10px;
      font-family: inherit;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      background: transparent;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .btn-restore {
      border: 1px solid rgba(16, 185, 129, 0.3);
      color: var(--success);
      background: rgba(16, 185, 129, 0.05);
    }

    .btn-restore:hover {
      background: var(--success);
      color: #fff;
      box-shadow: 0 4px 15px rgba(16, 185, 129, 0.25);
      transform: translateY(-1px);
    }

    .btn-delete {
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: var(--danger);
      background: rgba(239, 68, 68, 0.05);
    }

    .btn-delete:hover {
      background: var(--danger);
      color: #fff;
      box-shadow: 0 4px 15px rgba(239, 68, 68, 0.25);
      transform: translateY(-1px);
    }

    /* Pagination */
    .pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
      margin-top: 40px;
    }

    .page-link {
      padding: 8px 16px;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      transition: all 0.3s;
      background: rgba(24, 24, 27, 0.2);
    }

    .page-link:hover {
      border-color: var(--text-muted);
      color: #fff;
    }

    .page-link.active {
      background: #8b5cf6;
      border-color: #8b5cf6;
      color: #fff;
      box-shadow: 0 4px 12px rgba(139, 92, 246, 0.25);
    }

    .empty-state {
      background: var(--card-bg);
      border: 1px dashed var(--border-color);
      border-radius: 18px;
      padding: 60px 24px;
      text-align: center;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    .empty-icon {
      font-size: 3rem;
      margin-bottom: 16px;
      color: var(--text-muted);
    }

    .empty-title {
      font-family: 'Outfit', sans-serif;
      font-size: 1.4rem;
      font-weight: 600;
      margin-bottom: 8px;
    }

    .empty-desc {
      color: var(--text-muted);
      font-size: 0.95rem;
    }

    @media (max-width: 640px) {
      .navbar {
        padding: 12px 16px;
      }
      .main-content {
        padding: 24px 16px;
      }
      .request-card {
        padding: 20px;
      }
      .actions {
        justify-content: stretch;
      }
      .btn-restore, .btn-delete {
        flex: 1;
        justify-content: center;
      }
    }
  </style>
</head>
<body>

  <header class="navbar">
    <div class="nav-container">
      <a href="/admin/dashboard" class="brand">
        <span class="brand-dot"></span>
        Portfolio Admin
      </a>
      <a href="/admin/dashboard" class="nav-link">Active Inbox</a>
      <a href="/admin/archives" class="nav-link active">Archives</a>
      <a href="/admin/logout" class="btn-logout">Logout</a>
    </div>
  </header>

  <main class="main-content">
    <div class="welcome-header">
      <h2>Archived Inquiries</h2>
      <p>Review and manage messages that you have archived</p>
    </div>

    <!-- Stats Panel -->
    <section class="stats-grid">
      <div class="stats-card">
        <span class="stats-title">Total Archived Inquiries</span>
        <span class="stats-value"><%= total %></span>
      </div>
      <div class="stats-card">
        <span class="stats-title">Showing Page</span>
        <span class="stats-value" style="font-size: 1.8rem; font-family: 'Outfit', sans-serif; margin-top: auto; font-weight: 600;">
          <%= totalPages > 0 ? page + ' of ' + totalPages : '0 of 0' %>
        </span>
      </div>
    </section>

    <!-- Controls Panel -->
    <section class="controls-panel">
      <form action="/admin/archives" method="GET" class="search-form">
        <input 
          type="text" 
          name="search" 
          placeholder="Search archives by name, email, subject, or message..." 
          class="search-input"
          value="<%= search %>"
        >
        <button type="submit" class="btn-search">Search</button>
        <% if (search) { %>
          <a href="/admin/archives" class="btn-clear-search">Clear</a>
        <% } %>
      </form>
    </section>

    <!-- Messages List Section -->
    <section>
      <h3 class="section-title">
        Archive List
        <span class="badge-count"><%= total %></span>
      </h3>

      <% if (requests.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">📁</div>
          <h4 class="empty-title">
            <%= search ? 'No matching archived inquiries' : 'Archive is empty' %>
          </h4>
          <p class="empty-desc">
            <%= search ? 'Try checking your search terms or refining your query.' : 'Any messages you archive will appear here.' %>
          </p>
        </div>
      <% } else { %>
        <div class="requests-list">
          <% requests.forEach(function(req) { %>
            <div class="request-card" id="card-<%= req._id %>">
              <div class="request-header">
                <div class="sender-info">
                  <h3><%= req.name %></h3>
                  <a href="mailto:<%= req.email %>" class="sender-email"><%= req.email %></a>
                </div>
                <div class="request-date request-date-local" data-date="<%= req.createdAt.toISOString() %>">
                  <%= req.createdAt.toISOString() %>
                </div>
              </div>

              <% if (req.subject) { %>
                <div class="request-subject">
                  <span class="subject-prefix">Subject:</span>
                  <span><%= req.subject %></span>
                </div>
              <% } %>

              <div class="request-message"><%= req.message %></div>

              <div class="actions">
                <!-- Restore (Unarchive) Button -->
                <button type="button" class="btn-restore" title="Restore to Active Inbox" onclick="handleAction('unarchive', '<%= req._id %>', 'Are you sure you want to restore this inquiry to active inbox?')">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12a10 10 0 1 0 10-10H2"></path><polyline points="12 2 2 2 2 12"></polyline><path d="M12 6v6l4 2"></path></svg>
                  Restore
                </button>

                <!-- Delete Button -->
                <button type="button" class="btn-delete" title="Delete Inquiry" onclick="handleAction('delete', '<%= req._id %>', 'Are you sure you want to permanently delete this inquiry? This cannot be undone.')">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                  Delete
                </button>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- Pagination Controls -->
        <% if (totalPages > 1) { %>
          <div class="pagination">
            <% if (page > 1) { %>
              <a href="/admin/archives?page=<%= page - 1 %>&search=<%= encodeURIComponent(search) %>" class="page-link">&laquo; Prev</a>
            <% } %>

            <% for (let i = 1; i <= totalPages; i++) { %>
              <a href="/admin/archives?page=<%= i %>&search=<%= encodeURIComponent(search) %>" class="page-link <%= page === i ? 'active' : '' %>"><%= i %></a>
            <% } %>

            <% if (page < totalPages) { %>
              <a href="/admin/archives?page=<%= page + 1 %>&search=<%= encodeURIComponent(search) %>" class="page-link">Next &raquo;</a>
            <% } %>
          </div>
        <% } %>
      <% } %>
    </section>
  </main>

  <script>
    async function handleAction(action, id, confirmMessage) {
      if (confirmMessage && !confirm(confirmMessage)) {
        return;
      }

      try {
        const response = await fetch(`/admin/contact/${id}/${action}`, {
          method: 'POST',
          credentials: 'same-origin',
          headers: {
            'Accept': 'application/json'
          }
        });

        const result = await response.json();
        if (result.success) {
          const card = document.getElementById(`card-${id}`);
          if (card) {
            // Smooth fadeout animation
            card.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
            card.style.opacity = '0';
            card.style.transform = 'translateY(15px) scale(0.95)';
            
            setTimeout(() => {
              card.remove();
              
              // Update badge counts dynamically
              const countBadges = document.querySelectorAll('.badge-count');
              const statsValue = document.querySelector('.stats-value');
              
              let newCount = 0;
              countBadges.forEach(badge => {
                newCount = Math.max(0, parseInt(badge.textContent) - 1);
                badge.textContent = newCount;
              });

              if (statsValue) {
                statsValue.textContent = newCount;
              }
              
              // If page is empty after action, reload to rebuild pagination
              const list = document.querySelector('.requests-list');
              if (list && list.children.length === 0) {
                location.reload();
              }
            }, 400);
          }
        } else {
          alert(result.message || 'Operation failed');
        }
      } catch (err) {
        console.error('Action error:', err);
        alert('An error occurred. Please try again.');
      }
    }

    // Format UTC dates to browser local time on page load
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.request-date-local').forEach(el => {
        const utcDateStr = el.getAttribute('data-date');
        if (utcDateStr) {
          const localDate = new Date(utcDateStr);
          el.textContent = localDate.toLocaleString('en-US', { 
            dateStyle: 'medium', 
            timeStyle: 'short' 
          });
        }
      });
    });
  </script>

</body>
</html>
